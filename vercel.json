{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.3.0",
      "maxDuration": 60,
      "includeFiles": "{app/**,chatbots/**,widget_dist/**}"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ],
  "env": {
    "DATABASE_PATH": "/tmp/badboerdi.db"
  }
}
